# Groq API Configuration
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_api_key_here

# Optional: Model selection (default is llama-2-70b-chat)
GROQ_MODEL=llama-2-70b-chat

# Optional: API timeout in seconds
API_TIMEOUT=30

# Optional: Rate limiting delay between requests (seconds)
REQUEST_DELAY=5

# Optional: Verbosity level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
